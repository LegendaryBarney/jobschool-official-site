# 賈伯斯數理教室官方網站 — 環境變數範本
# 複製本檔為 .env 並填入實際值。所有 PUBLIC_ 前綴變數會被打包至前端。

# 試聽表單寄信服務（Resend）
RESEND_API_KEY=

# Cloudflare Turnstile 防 Spam
TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=

# Sentry 錯誤監控
SENTRY_DSN=
PUBLIC_SENTRY_DSN=

# Google Analytics 4
PUBLIC_GA_ID=

# Microsoft Clarity
PUBLIC_CLARITY_ID=

# Meta Pixel（Facebook/Instagram 廣告再行銷與轉換追蹤）
PUBLIC_META_PIXEL_ID=

# Google Search Console 網站驗證（meta 標籤驗證法）
PUBLIC_GSC_VERIFICATION=

# LINE 官方帳號連結（CTA 用）
PUBLIC_LINE_URL=

# 社群連結（Footer 與 JSON-LD sameAs；留空則 fallback 至 seo.ts 內建值）
PUBLIC_INSTAGRAM_URL=
PUBLIC_FACEBOOK_URL=
PUBLIC_YOUTUBE_URL=
PUBLIC_GOOGLE_BUSINESS_URL=

# 表單寄信目標
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=

# 站台 URL（覆寫 astro.config 預設）
PUBLIC_SITE_URL=https://jobsedu.com.tw

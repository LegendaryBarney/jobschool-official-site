{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config:*)",
      "Bash(git push:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(gh:*)",
      "Bash(vercel:*)",
      "Bash(pagefind:*)",
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Glob(**)",
      "Grep(**)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__playwright",
      "mcp__chrome-devtools",
      "mcp__context7"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin HEAD:main:*)",
      "Bash(git push --set-upstream origin main:*)",
      "Bash(git push -u origin main:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -d:*)",
      "Bash(git clean -x:*)",
      "Bash(git branch -D:*)",
      "Bash(git push origin --delete:*)",
      "Bash(vercel rollback:*)",
      "Bash(vercel alias:*)",
      "Bash(vercel dns:*)",
      "Bash(vercel domains:*)",
      "Bash(vercel remove:*)",
      "Bash(vercel rm:*)",
      "Bash(rm -rf:*)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(secrets/**)",
      "Edit(secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard.mjs\""
          }
        ]
      }
    ]
  }
}

---
import { ClientRouter } from 'astro:transitions';
import Fonts from '~/components/Fonts.astro';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';
import MobileStickyCTA from '~/components/MobileStickyCTA.astro';
import SmoothScroll from '~/components/SmoothScroll.astro';
import SiteScripts from '~/components/SiteScripts.astro';
import { buildMeta, buildOgImageUrl, SITE } from '~/lib/seo';
import '~/styles/global.css';

type JsonLdValue = Record<string, unknown> | Record<string, unknown>[];

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** 別名：image — 為了相容舊頁面 */
  image?: string;
  canonical?: string;
  noindex?: boolean;
  hideMobileCta?: boolean;
  jsonLd?: JsonLdValue;
}

const {
  title,
  description,
  ogImage,
  image,
  canonical: canonicalProp,
  noindex,
  hideMobileCta = false,
  jsonLd,
} = Astro.props;

// 若呼叫端沒指定 ogImage / image，且有 title，就自動用動態 OG 路由
const explicitOg = ogImage ?? image;
const autoOg = !explicitOg && title
  ? buildOgImageUrl({
      slug: Astro.url.pathname.replace(/^\/+|\/+$/g, '') || 'home',
      title,
      subtitle: description,
    })
  : undefined;

const meta = buildMeta({
  title,
  description,
  image: explicitOg ?? autoOg,
  canonical: canonicalProp,
});

const siteOrigin = Astro.site ?? new URL('https://jobschool-edu.com');
const canonical = canonicalProp ?? new URL(Astro.url.pathname, siteOrigin).toString();
const resolvedOg = meta.image?.startsWith('http')
  ? meta.image
  : new URL(meta.image ?? '/og-default.png', siteOrigin).toString();

const jsonLdArray: Record<string, unknown>[] = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

// Analytics IDs（缺值時不渲染）
const GA_ID = (import.meta.env.PUBLIC_GA_ID as string | undefined) ?? '';
const CLARITY_ID = (import.meta.env.PUBLIC_CLARITY_ID as string | undefined) ?? '';
const META_PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID as string | undefined) ?? '';
const GSC_VERIFICATION = (import.meta.env.PUBLIC_GSC_VERIFICATION as string | undefined) ?? '';
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#F5EFE6" />
    <meta name="generator" content={Astro.generator} />
    {/* Google Search Console 網站驗證 — 缺值時不渲染 */}
    {GSC_VERIFICATION && <meta name="google-site-verification" content={GSC_VERIFICATION} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    {(noindex || meta.noindex) && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={meta.type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOg} />
    <meta property="og:locale" content="zh_TW" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={resolvedOg} />

    {/* RSS / sitemap discovery */}
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} 部落格`} href="/feed.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    {jsonLdArray.map((data) => (
      <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(data)}
      />
    ))}

    <Fonts />
    <ClientRouter />

    {/* Google Analytics 4 — 條件渲染，尊重 DNT，搭配 View Transitions 重發 page_view */}
    {GA_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>{`
          (function () {
            try {
              if (typeof navigator !== 'undefined' && navigator.doNotTrack === '1') return;
              window.dataLayer = window.dataLayer || [];
              function gtag(){ window.dataLayer.push(arguments); }
              window.gtag = gtag;
              gtag('js', new Date());
              gtag('config', GA_ID, { send_page_view: true });
              document.addEventListener('astro:after-swap', function () {
                if (typeof window.gtag !== 'function') return;
                window.gtag('event', 'page_view', {
                  page_path: location.pathname + location.search,
                  page_location: location.href,
                  page_title: document.title,
                });
              });
            } catch (e) { /* swallow */ }
          })();
        `}</script>
      </>
    )}

    {/* Microsoft Clarity */}
    {CLARITY_ID && (
      <script is:inline define:vars={{ CLARITY_ID }}>{`
        (function (c, l, a, r, i, t, y) {
          if (typeof navigator !== 'undefined' && navigator.doNotTrack === '1') return;
          c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
          t = l.createElement(r); t.async = 1;
          t.src = 'https://www.clarity.ms/tag/' + i;
          y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
        })(window, document, 'clarity', 'script', CLARITY_ID);
      `}</script>
    )}

    {/* Meta Pixel — 條件渲染，尊重 DNT，搭配 View Transitions 重發 PageView */}
    {META_PIXEL_ID && (
      <>
        <script is:inline define:vars={{ META_PIXEL_ID }}>{`
          (function (f, b, e, v, n, t, s) {
            if (typeof navigator !== 'undefined' && navigator.doNotTrack === '1') return;
            if (f.fbq) return; n = f.fbq = function () {
              n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
            };
            if (!f._fbq) f._fbq = n;
            n.push = n; n.loaded = !0; n.version = '2.0'; n.queue = [];
            t = b.createElement(e); t.async = !0; t.src = v;
            s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
            f.fbq('init', META_PIXEL_ID);
            f.fbq('track', 'PageView');
            b.addEventListener('astro:after-swap', function () {
              if (typeof f.fbq === 'function') f.fbq('track', 'PageView');
            });
          })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
        `}</script>
        <noscript>
          <img
            height="1"
            width="1"
            style="display:none"
            alt=""
            src={`https://www.facebook.com/tr?id=${META_PIXEL_ID}&ev=PageView&noscript=1`}
          />
        </noscript>
      </>
    )}

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-latte text-charcoal">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded-md focus:bg-caramel focus:px-3 focus:py-2 focus:text-charcoal">
      跳至主要內容
    </a>
    <Nav />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    {!hideMobileCta && <MobileStickyCTA />}

    <SmoothScroll />
    <SiteScripts />

    {/* 全站 LINE 點擊轉換追蹤：事件委派一次涵蓋所有 LINE CTA（Nav / Footer / 行動 sticky / 表單成功頁）。
        缺 GA/Pixel 時不渲染；點擊不阻擋導流。LINE 加好友是補習班核心轉換動作，需單獨計數。 */}
    {(GA_ID || META_PIXEL_ID) && (
      <script is:inline>{`
        (function () {
          document.addEventListener('click', function (e) {
            var a = e.target && e.target.closest ? e.target.closest('a[href*="line.me"], a[href*="lin.ee"]') : null;
            if (!a) return;
            try { if (typeof window.gtag === 'function') window.gtag('event', 'line_click', { event_category: 'engagement', link_url: a.href }); } catch (_) {}
            try { if (typeof window.fbq === 'function') window.fbq('trackCustom', 'LineClick', { url: a.href }); } catch (_) {}
          }, true);
        })();
      `}</script>
    )}

    {/* Pagefind UI script 預留（build 後 /pagefind/ 才會生成） */}
  </body>
</html>

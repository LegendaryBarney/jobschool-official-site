---
// 注意：本元件「只負責視覺麵包屑」，不再輸出 BreadcrumbList JSON-LD。
// 結構化資料一律由頁面層用 breadcrumbJsonLd(...) 傳入 BaseLayout 的 jsonLd，
// 以確保每個有麵包屑的頁面有且僅有一份 BreadcrumbList（避免重複）。
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;

const fullItems: BreadcrumbItem[] = items[0]?.label === '首頁'
  ? items
  : [{ label: '首頁', href: '/' }, ...items];
---

<nav aria-label="麵包屑" class={`text-sm text-charcoal/70 ${className}`}>
  <ol class="flex flex-wrap items-center gap-1.5">
    {
      fullItems.map((it, idx) => {
        const isLast = idx === fullItems.length - 1;
        return (
          <li class="flex items-center gap-1.5">
            {idx > 0 && <span aria-hidden="true" class="text-charcoal/40">/</span>}
            {isLast || !it.href ? (
              <span aria-current={isLast ? 'page' : undefined} class="text-charcoal">
                {it.label}
              </span>
            ) : (
              <a href={it.href} class="text-espresso hover:text-caramel transition-colors">
                {it.label}
              </a>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

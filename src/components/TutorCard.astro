---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Tag from './Tag.astro';

interface Props {
  tutor: CollectionEntry<'tutoring'>;
  class?: string;
}

const { tutor, class: className = '' } = Astro.props;
const { name, subject, summary, format, trialDuration, cover } = tutor.data;
const slug = tutor.id.replace(/\.(md|mdx)$/, '');
const href = `/tutors/${slug}`;

const formatLabel = format === '遠端' ? '遠端授課' : format === '皆可' ? '遠端 / 實體' : '實體授課';
---

<article
  class={`tutor-card group flex flex-col overflow-hidden rounded-xl bg-chalk border border-cream transition-[transform,box-shadow] duration-300 ease-[var(--ease-brand)] hover:-translate-y-1 hover:shadow-md ${className}`}
>
  {cover && (
    <a href={href} class="block aspect-[16/10] overflow-hidden bg-cream">
      <Image
        src={cover}
        alt={name}
        widths={[480, 768]}
        sizes="(max-width: 768px) 100vw, 380px"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      />
    </a>
  )}

  <div class="flex flex-1 flex-col p-5">
    <div class="flex flex-wrap items-center gap-2">
      <span class="inline-flex items-center rounded-md bg-caramel/25 px-2 py-0.5 text-xs font-semibold text-espresso">
        1v1 家教
      </span>
      <Tag size="sm">{subject}</Tag>
      <span class="inline-flex items-center rounded-md bg-cream px-2 py-0.5 text-xs text-charcoal/70">
        {formatLabel}
      </span>
    </div>

    <h3 class="mt-3 font-serif text-xl font-bold text-charcoal">
      <a href={href} class="hover:text-espresso transition-colors">{name}</a>
    </h3>
    <p class="mt-2 text-sm text-charcoal/80 leading-relaxed line-clamp-3">{summary}</p>

    <div class="mt-4 flex items-center justify-between border-t border-cream/80 pt-4">
      <span class="text-xs text-charcoal/65">{trialDuration}</span>
      <a
        href={href}
        class="inline-flex items-center gap-1 text-sm font-medium text-espresso hover:text-caramel transition-colors"
      >
        了解詳情
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</article>

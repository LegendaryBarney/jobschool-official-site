---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Tag from './Tag.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  class?: string;
}

const { post, class: className = '' } = Astro.props;
const { title, summary, published, updated, tags, cover, category } = post.data;
const href = `/posts/${post.slug}`;

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('zh-Hant-TW', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(d);
---

<article
  class={`post-card group flex flex-col overflow-hidden rounded-xl bg-chalk border border-cream transition-[transform,box-shadow] duration-300 ease-[var(--ease-brand)] hover:-translate-y-1 hover:shadow-md ${className}`}
>
  {cover && (
    <a href={href} class="block aspect-[16/9] overflow-hidden bg-cream">
      <Image
        src={cover}
        alt={title}
        widths={[480, 768, 1024]}
        sizes="(max-width: 768px) 100vw, 400px"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      />
    </a>
  )}

  <div class="flex flex-1 flex-col p-5">
    {category && (
      <span class="text-xs font-medium uppercase tracking-wider text-espresso">{category}</span>
    )}
    <h3 class="mt-1 font-serif text-xl font-bold text-charcoal leading-snug">
      <a href={href} class="hover:text-espresso transition-colors">{title}</a>
    </h3>
    <p class="mt-2 text-sm text-charcoal/80 leading-relaxed line-clamp-3">{summary}</p>

    {tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((t) => <li><Tag size="sm">{t}</Tag></li>)}
      </ul>
    )}

    <div class="mt-auto pt-4 flex items-center justify-between text-xs text-charcoal/60">
      <time datetime={published.toISOString()}>{fmt(published)}</time>
      {updated && (
        <span>
          · 更新於 <time datetime={updated.toISOString()}>{fmt(updated)}</time>
        </span>
      )}
    </div>
  </div>
</article>

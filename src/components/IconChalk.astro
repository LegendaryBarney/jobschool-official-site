---
/**
 * IconChalk — 通用線稿 icon wrapper（粉筆/手繪感）
 * 使用方式：<IconChalk name="cup|book|chalk|sparkle|users|target|spark|pi" />
 */
type IconName =
  | 'cup'
  | 'book'
  | 'chalk'
  | 'sparkle'
  | 'users'
  | 'target'
  | 'spark'
  | 'pi'
  | 'compass'
  | 'pen'
  | 'flag'
  | 'note';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  ariaLabel?: string;
}

const { name, size = 36, class: className = '', ariaLabel } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`text-espresso ${className}`}
  role={ariaLabel ? 'img' : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : 'true'}
>
  {name === 'cup' && (
    <g>
      <path d="M10 18h22v10a8 8 0 0 1-8 8h-6a8 8 0 0 1-8-8V18Z" />
      <path d="M32 21h4a4 4 0 0 1 0 8h-4" />
      <path d="M14 8c2 1.5 2 3.5 0 5M20 8c2 1.5 2 3.5 0 5M26 8c2 1.5 2 3.5 0 5" />
      <path d="M8 40h28" />
    </g>
  )}
  {name === 'book' && (
    <g>
      <path d="M8 10c4-1 12-1 16 2 4-3 12-3 16-2v26c-4-1-12-1-16 2-4-3-12-3-16-2V10Z" />
      <path d="M24 12v28" />
    </g>
  )}
  {name === 'chalk' && (
    <g>
      <rect x="10" y="20" width="28" height="8" rx="1.5" transform="rotate(-15 24 24)" />
      <path d="M30 14l4 4" />
    </g>
  )}
  {name === 'sparkle' && (
    <g>
      <path d="M24 6v10M24 32v10M6 24h10M32 24h10" />
      <path d="M12 12l6 6M30 30l6 6M36 12l-6 6M18 30l-6 6" />
    </g>
  )}
  {name === 'users' && (
    <g>
      <circle cx="18" cy="18" r="5" />
      <circle cx="32" cy="20" r="4" />
      <path d="M8 38c1-6 5-9 10-9s9 3 10 9" />
      <path d="M28 38c1-4 4-7 8-7s7 3 8 7" />
    </g>
  )}
  {name === 'target' && (
    <g>
      <circle cx="24" cy="24" r="16" />
      <circle cx="24" cy="24" r="9" />
      <circle cx="24" cy="24" r="3" />
    </g>
  )}
  {name === 'spark' && (
    <g>
      <path d="M24 6l4 14 14 4-14 4-4 14-4-14-14-4 14-4 4-14Z" />
    </g>
  )}
  {name === 'pi' && (
    <g>
      <path d="M10 16h28" />
      <path d="M16 16v18M30 16v14a4 4 0 0 0 4 4" />
    </g>
  )}
  {name === 'compass' && (
    <g>
      <circle cx="24" cy="24" r="16" />
      <path d="M30 18l-3 9-9 3 3-9 9-3Z" />
    </g>
  )}
  {name === 'pen' && (
    <g>
      <path d="M30 8l10 10-22 22H8V28L30 8Z" />
      <path d="M26 12l10 10" />
    </g>
  )}
  {name === 'flag' && (
    <g>
      <path d="M10 6v36" />
      <path d="M10 8h22l-4 6 4 6H10" />
    </g>
  )}
  {name === 'note' && (
    <g>
      <path d="M12 6h18l8 8v28H12V6Z" />
      <path d="M30 6v8h8" />
      <path d="M18 22h14M18 28h14M18 34h10" />
    </g>
  )}
</svg>

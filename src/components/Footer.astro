---
import { getCollection } from 'astro:content';
import { LOCATIONS } from '~/lib/locations';
import { getActiveSocials, type SocialKey } from '~/lib/seo';

const lineUrl = import.meta.env.PUBLIC_LINE_URL || '#';

const socialMeta: Record<SocialKey, { label: string }> = {
  instagram: { label: 'Instagram' },
  facebook: { label: 'Facebook' },
  youtube: { label: 'YouTube' },
  googleBusiness: { label: 'Google 商家' },
};

const activeSocials = getActiveSocials();

const siteMap = [
  { href: '/', label: '首頁' },
  { href: '/about', label: '關於我們' },
  { href: '/courses', label: '課程' },
  { href: '/tutors', label: '1對1家教' },
  { href: '/teachers', label: '師資' },
  { href: '/fees', label: '收費與退費' },
  { href: '/schedule', label: '課表' },
  { href: '/policy', label: '課務說明' },
  { href: '/posts', label: '部落格' },
  { href: '/testimonials', label: '學生見證' },
  { href: '/faq', label: '常見問題' },
  { href: '/locations', label: '教室據點' },
  { href: '/contact', label: '聯絡我們' },
];

const shinobi = LOCATIONS.shinobi;

let testimonials: Array<{
  studentName: string;
  grade?: string;
  school?: string;
  quote: string;
}> = [];

try {
  const all = await getCollection('testimonials');
  testimonials = all
    .filter((t) => t.data.featured)
    .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
    .slice(0, 3)
    .map((t) => ({
      studentName: t.data.studentName,
      grade: t.data.grade,
      school: t.data.school,
      quote: t.data.quote,
    }));
} catch {
  testimonials = [];
}
---

<footer id="site-footer" class="mt-24 bg-cream/60 paper-grain border-t border-cream">
  <div class="mx-auto max-w-6xl px-4 py-12 lg:px-8 lg:py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <h3 class="font-serif text-xl font-bold text-charcoal">賈伯斯數理教室</h3>
        <p class="mt-3 text-sm text-charcoal/80 leading-relaxed">
          嘉義在地的精緻小班補習機構，由臺、交、高師大、嘉義大學、臺北市立大學資歷師資組成，專攻國中至高中數理與英文科目。
        </p>
        <address class="mt-4 not-italic text-sm text-charcoal/80 leading-relaxed">
          <span class="block">嘉義市東區康樂街 10 號</span>
          <span class="block">電話：<a href="tel:+88652230303" class="hover:text-espresso">(05) 223-0303</a></span>
          <span class="block mt-1">營業時間：週一至週六 14:00–22:00</span>
          <span class="block">週日休</span>
        </address>
        <a
          href={lineUrl}
          target={lineUrl !== '#' ? '_blank' : undefined}
          rel={lineUrl !== '#' ? 'noopener noreferrer' : undefined}
          class="mt-5 inline-flex items-center gap-2 rounded-lg border border-espresso bg-chalk px-4 py-2 text-sm text-espresso transition-colors hover:bg-cream"
        >
          <span aria-hidden="true">→</span>
          加 LINE 詢問課程
        </a>

        {
          activeSocials.length > 0 && (
            <nav class="mt-5 flex items-center gap-3" aria-label="社群連結">
              {activeSocials.map(({ key, url }) => (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={socialMeta[key].label}
                  title={socialMeta[key].label}
                  class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-cream bg-chalk text-espresso transition-colors hover:bg-cream hover:text-charcoal"
                >
                  {key === 'instagram' && (
                    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
                      <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.5.01-4.74.07-1.14.05-1.76.24-2.17.4-.55.21-.94.47-1.35.88-.41.41-.67.8-.88 1.35-.16.41-.35 1.03-.4 2.17-.06 1.24-.07 1.59-.07 4.74s.01 3.5.07 4.74c.05 1.14.24 1.76.4 2.17.21.55.47.94.88 1.35.41.41.8.67 1.35.88.41.16 1.03.35 2.17.4 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c1.14-.05 1.76-.24 2.17-.4.55-.21.94-.47 1.35-.88.41-.41.67-.8.88-1.35.16-.41.35-1.03.4-2.17.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.05-1.14-.24-1.76-.4-2.17a3.6 3.6 0 0 0-.88-1.35 3.6 3.6 0 0 0-1.35-.88c-.41-.16-1.03-.35-2.17-.4-1.24-.06-1.59-.07-4.74-.07Zm0 2.76a5.3 5.3 0 1 1 0 10.6 5.3 5.3 0 0 1 0-10.6Zm0 1.62a3.68 3.68 0 1 0 0 7.36 3.68 3.68 0 0 0 0-7.36Zm5.48-2.9a1.24 1.24 0 1 1 0 2.48 1.24 1.24 0 0 1 0-2.48Z" />
                    </svg>
                  )}
                  {key === 'facebook' && (
                    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
                      <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.48h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.91h-2.34V22c4.78-.76 8.43-4.92 8.43-9.94Z" />
                    </svg>
                  )}
                  {key === 'youtube' && (
                    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
                      <path d="M23.5 6.5a3.02 3.02 0 0 0-2.12-2.14C19.5 3.86 12 3.86 12 3.86s-7.5 0-9.38.5A3.02 3.02 0 0 0 .5 6.5C0 8.4 0 12 0 12s0 3.6.5 5.5a3.02 3.02 0 0 0 2.12 2.14c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.02 3.02 0 0 0 2.12-2.14c.5-1.9.5-5.5.5-5.5s0-3.6-.5-5.5ZM9.6 15.57V8.43L15.82 12 9.6 15.57Z" />
                    </svg>
                  )}
                  {key === 'googleBusiness' && (
                    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
                      <path d="M12 10.18v3.82h5.4a4.62 4.62 0 0 1-2 3.03v2.5h3.24c1.9-1.75 3-4.33 3-7.4 0-.72-.07-1.4-.18-2.06H12Z" />
                      <path d="M12 22c2.7 0 4.97-.9 6.63-2.43l-3.24-2.5c-.9.6-2.05.96-3.39.96-2.6 0-4.8-1.76-5.6-4.12H3.07v2.59A10 10 0 0 0 12 22Z" />
                      <path d="M6.4 13.91A6 6 0 0 1 6.08 12c0-.66.12-1.31.32-1.91V7.5H3.07A10 10 0 0 0 2 12c0 1.62.39 3.15 1.07 4.5l3.33-2.59Z" />
                      <path d="M12 5.97c1.47 0 2.78.5 3.82 1.49l2.86-2.86A9.6 9.6 0 0 0 12 2 10 10 0 0 0 3.07 7.5L6.4 10.1C7.2 7.73 9.4 5.97 12 5.97Z" />
                    </svg>
                  )}
                </a>
              ))}
            </nav>
          )
        }

        <div class="mt-6 pt-5 border-t border-cream/80">
          <p class="text-xs font-semibold tracking-wider text-espresso uppercase">姊妹品牌</p>
          <p class="mt-2 text-sm font-medium text-charcoal">{shinobi.name}</p>
          <address class="not-italic text-xs text-charcoal/70 leading-relaxed">
            {shinobi.address}
            {shinobi.foundedYear && <span class="text-charcoal/50"> · EST. {shinobi.foundedYear}</span>}
          </address>
          <a href="/locations" class="mt-2 inline-block text-xs text-espresso hover:underline">
            兩教室據點與地圖 →
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-sans text-sm font-semibold tracking-wider text-espresso uppercase">
          網站地圖
        </h4>
        <ul class="mt-3 grid grid-cols-2 gap-2 text-sm">
          {
            siteMap.map((c) => (
              <li>
                <a href={c.href} class="text-charcoal hover:text-espresso transition-colors">
                  {c.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="font-sans text-sm font-semibold tracking-wider text-espresso uppercase">
          學生回饋精選
        </h4>
        {testimonials.length > 0 ? (
          <ul class="mt-3 space-y-3 text-sm">
            {
              testimonials.map((t) => (
                <li class="border-l-2 border-caramel pl-3">
                  <p class="text-charcoal/80 leading-relaxed line-clamp-3">「{t.quote}」</p>
                  <p class="mt-1 text-xs text-charcoal/60">
                    — {t.studentName}
                    {t.school ? ` · ${t.school}` : ''}
                    {t.grade ? ` · ${t.grade}` : ''}
                  </p>
                </li>
              ))
            }
          </ul>
        ) : (
          <p class="mt-3 text-sm text-charcoal/70 leading-relaxed">
            過去 12 年來，累積上千位嘉義在地學生在這裡踏實累積。
            <a href="/testimonials" class="block mt-2 text-espresso hover:underline">
              查看所有學生見證 →
            </a>
          </p>
        )}
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-cream/80 flex flex-col gap-3 md:flex-row md:items-center md:justify-between text-xs text-charcoal/60">
      <span>&copy; 2014–2026 賈伯斯數理教室</span>
      <ul class="flex flex-wrap gap-x-4 gap-y-1">
        <li><a href="#" class="hover:text-espresso">隱私權政策</a></li>
        <li><a href="#" class="hover:text-espresso">Cookie 設定</a></li>
        <li><a href="/contact" class="hover:text-espresso">聯絡我們</a></li>
      </ul>
      <span class="text-charcoal/50">網站由業主自行維護</span>
    </div>
  </div>
</footer>

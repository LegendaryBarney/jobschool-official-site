---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Tag from './Tag.astro';

interface Props {
  teacher: CollectionEntry<'teachers'>;
  href?: string;
  class?: string;
}

const { teacher, href, class: className = '' } = Astro.props;
const { name, title, photo, yearsOfExperience, subjects } = teacher.data;
const linkHref = href ?? `/teachers/${teacher.slug}`;
---

<a
  href={linkHref}
  class={`teacher-card group block rounded-xl bg-chalk border border-cream p-5 transition-[transform,box-shadow] duration-300 ease-[var(--ease-brand)] hover:shadow-md ${className}`}
  aria-label={`查看 ${name} 老師介紹`}
>
  <div class="aspect-[4/5] overflow-hidden rounded-lg bg-cream">
    {photo ? (
      <Image
        src={photo}
        alt={`${name} 老師`}
        widths={[240, 480]}
        sizes="(max-width: 768px) 50vw, 320px"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-espresso/40 font-serif text-3xl">
        {name.slice(0, 1)}
      </div>
    )}
  </div>

  <div class="mt-4">
    <h3 class="font-serif text-xl font-bold text-charcoal">{name}</h3>
    <p class="mt-1 text-sm text-espresso">{title}</p>
    {yearsOfExperience > 0 && (
      <p class="mt-1 text-xs text-charcoal/60">教學年資 {yearsOfExperience} 年</p>
    )}
    {subjects.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {subjects.slice(0, 4).map((s) => (
          <li><Tag size="sm">{s}</Tag></li>
        ))}
      </ul>
    )}
  </div>
</a>

<style>
  .teacher-card {
    transform-style: preserve-3d;
    perspective: 800px;
    transition-property: transform, box-shadow;
  }
  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .teacher-card:hover {
      transform: translateY(-4px) rotateX(2deg) rotateY(-2deg);
    }
  }
</style>

---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import SectionFadeUp from '~/components/SectionFadeUp.astro';
import Button from '~/components/Button.astro';
import Countdown from '~/components/Countdown.astro';
import TrialForm from '~/components/TrialForm';
import IconChalk from '~/components/IconChalk.astro';
import { breadcrumbJsonLd, webPageJsonLd } from '~/lib/jsonld';
import { SITE } from '~/lib/seo';

export async function getStaticPaths() {
  const lps = await getCollection('landing', ({ data }) => data.published);
  return lps.map((lp) => ({
    params: { campaign: lp.data.campaign },
    props: { entry: lp },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'landing'> };
const { Content } = await render(entry);
const { title, headline, subheadline, ctaLabel, ctaHref, heroImage, startDate, endDate } = entry.data;

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('zh-Hant-TW', { dateStyle: 'long' }).format(d);

const sellingPoints = [
  { icon: 'users' as const, label: '極小班 / 精緻班 / 小班', desc: '依科目與年級配置 2-14 人多種規模' },
  { icon: 'cup' as const, label: '臺、清、交、嘉大、高師大資歷師資', desc: '由臺大資工碩士領軍' },
  { icon: 'note' as const, label: '自編教材與盲點筆記', desc: '過去 12 年累積精煉題型' },
  { icon: 'target' as const, label: '免費試聽', desc: '多數課程 2 節、特色課程 11 節，不滿意零壓力' },
];

const fullUrl = `${SITE.url}/lp/${entry.data.campaign}`;
const jsonLd = [
  webPageJsonLd({ name: title, description: headline, url: fullUrl }),
  breadcrumbJsonLd([
    { label: '首頁', href: SITE.url + '/' },
    { label: title, href: fullUrl },
  ]),
];
---

<BaseLayout
  title={title}
  description={`${headline}｜${subheadline ?? '賈伯斯數理教室嘉義東區精英小班'}`}
  jsonLd={jsonLd}
  hideExitIntent
>
  <div class="mx-auto max-w-6xl px-4 pt-6 lg:px-8">
    <Breadcrumbs items={[{ label: title }]} />
  </div>

  {/* Hero */}
  <section class="relative overflow-hidden bg-cream/40 paper-grain border-b border-cream">
    <div class="relative mx-auto max-w-5xl px-4 py-16 lg:px-8 lg:py-24 text-center">
      <p class="font-handwriting text-2xl text-espresso">嘉義 · 東區 · 康樂街</p>
      <h1 class="mt-3 font-serif text-4xl lg:text-6xl font-bold text-charcoal leading-tight">
        {headline}
      </h1>
      {subheadline && (
        <p class="mt-6 mx-auto max-w-3xl text-lg lg:text-xl text-charcoal/85 leading-relaxed">
          {subheadline}
        </p>
      )}

      {(startDate || endDate) && (
        <p class="mt-5 inline-flex items-center gap-2 rounded-full border border-cream bg-chalk px-4 py-1.5 text-sm text-charcoal/70">
          <span aria-hidden="true">📅</span>
          {startDate && <span>{fmtDate(startDate)}</span>}
          {startDate && endDate && <span>—</span>}
          {endDate && <span>{fmtDate(endDate)}</span>}
        </p>
      )}

      <div class="mt-10">
        <Button href={ctaHref} variant="primary" size="lg" magnetic>{ctaLabel}</Button>
      </div>

      {heroImage && (
        <div class="mt-12">
          <Image
            src={heroImage}
            alt={headline}
            widths={[640, 1024, 1280]}
            sizes="(max-width: 1024px) 100vw, 1024px"
            class="mx-auto rounded-xl border border-cream"
          />
        </div>
      )}
    </div>
  </section>

  {/* 賣點區 */}
  <SectionFadeUp>
    <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-20">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {sellingPoints.map((p) => (
          <article class="rounded-xl border border-cream bg-chalk p-5 text-center">
            <div class="mx-auto inline-flex">
              <IconChalk name={p.icon} size={36} />
            </div>
            <h3 class="mt-3 font-serif text-lg font-bold text-charcoal">{p.label}</h3>
            <p class="mt-2 text-sm text-charcoal/75 leading-relaxed">{p.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </SectionFadeUp>

  {/* 內文 */}
  <SectionFadeUp class="bg-cream/40 paper-grain border-y border-cream">
    <div class="mx-auto max-w-3xl px-4 py-12 lg:px-8 lg:py-16">
      <article class="prose prose-stone max-w-none prose-headings:font-serif prose-h2:text-2xl prose-h3:text-xl prose-a:text-espresso hover:prose-a:text-caramel prose-strong:text-charcoal prose-table:text-sm">
        <Content />
      </article>
    </div>
  </SectionFadeUp>

  {/* 倒數 + 試聽表單 */}
  <SectionFadeUp>
    <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-20">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
        <div class="space-y-6">
          {endDate && new Date() < endDate && (
            <Countdown endDate={endDate} label="活動結束倒數" />
          )}
          <div>
            <p class="font-handwriting text-2xl text-espresso">下一步</p>
            <h2 class="mt-2 font-serif text-3xl lg:text-4xl font-bold text-charcoal">
              現在預約，立即試聽
            </h2>
            <p class="mt-4 text-charcoal/80 leading-relaxed">
              填寫右側表單，我們會在 1 個工作日內以電話或 LINE 聯絡您。
              試聽免費，沒有任何壓力。
            </p>
          </div>
          <ul class="space-y-2 text-sm text-charcoal/80">
            <li class="flex gap-2"><span class="text-caramel">·</span> 試聽完全免費</li>
            <li class="flex gap-2"><span class="text-caramel">·</span> 不會在試聽當天就要求做決定</li>
            <li class="flex gap-2"><span class="text-caramel">·</span> 試聽後與家長 10 分鐘簡短溝通</li>
          </ul>
        </div>
        <div class="rounded-xl bg-chalk border border-cream p-5 lg:p-7">
          <TrialForm client:visible />
        </div>
      </div>
    </div>
  </SectionFadeUp>
</BaseLayout>

---
import PageLayout from '~/layouts/PageLayout.astro';
import TrialForm from '~/components/TrialForm';

const lineUrl = import.meta.env.PUBLIC_LINE_URL || '#';
---

<PageLayout
  title="聯絡我們 / 試聽預約"
  description="嘉義市東區康樂街 10 號 · (05)223-0303。歡迎填表預約免費試聽。"
  heading="聯絡我們"
  subheading="試聽是免費的，沒有壓力。"
>
  <div class="grid gap-10 lg:grid-cols-3">
    <aside class="space-y-6 text-sm text-charcoal/85">
      <div>
        <h3 class="font-semibold text-espresso">教室地址</h3>
        <p class="mt-2">嘉義市東區康樂街 10 號</p>
      </div>
      <div>
        <h3 class="font-semibold text-espresso">電話</h3>
        <p class="mt-2">(05)223-0303</p>
      </div>
      <div>
        <h3 class="font-semibold text-espresso">LINE 官方帳號</h3>
        <p class="mt-2">
          <a href={lineUrl} target="_blank" rel="noopener noreferrer" class="underline">
            點此加入
          </a>
        </p>
      </div>
    </aside>

    <div class="lg:col-span-2">
      <TrialForm client:load />
    </div>
  </div>
</PageLayout>

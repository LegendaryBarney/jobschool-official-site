---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import SectionFadeUp from '~/components/SectionFadeUp.astro';
import Button from '~/components/Button.astro';
import ScheduleFilter, { type ScheduleFilterRow } from '~/components/ScheduleFilter';
import { breadcrumbJsonLd, webPageJsonLd } from '~/lib/jsonld';
import { SITE } from '~/lib/seo';
import { getClassData, WEEKDAY_LABELS } from '~/lib/classData';

// ── 課表：資料驅動（getClassData → offerings 聚合）─────────────
// 設計目標（業主原話）：「課表依課程(科目+人)作為列，要給 filter/search
// 讓客戶看得懂、找得到」。因此：
//   - 列 = 一門課程（courseSlug）：科目為主、老師(name+englishName)為次。
//   - 欄 = 週一～週五；格 = 該日於哪些教室開課（短標籤，賈伯斯/忍）。
//   - 依學制（國中/高中）分組，加 grade 標籤。
//   - filter/search 由 ScheduleFilter 島漸進增強：SSR 渲染完整表格，
//     島只疊加篩選互動（DOM 顯示/隱藏），關閉 JS 仍可看完整課表。
const data = await getClassData();

// 固定週一～週五（index 1..5）。
const WEEKDAY_NUMS = [1, 2, 3, 4, 5] as const;

interface CourseRow {
  // 列鍵 = 學制+科目+老師（同一(科目+人)收成一列，符合業主「課程(科目+人)為列」定義）。
  rowKey: string;
  subject: string;
  teacherName: string;
  englishName: string | null;
  grade: '國中' | '高中';
  // 此(科目+人)涵蓋的課程名（如 高一/高二/高三數學三班），供顯示與搜尋。
  courseNames: string[];
  // 星期(1..5) → 該日授課教室短標籤清單；無授課之星期不入鍵。
  byDay: Map<number, string[]>;
  // 該列出現過的教室短標籤（去重，供篩選用）。
  locations: string[];
  // 排序用：該列涵蓋課程的最小 order。
  sortOrder: number;
}

// 以「學制+科目+老師」聚合 offerings 成「課程列」：
// 同一位老師、同一科目（同學制）的多個班（如高一/高二/高三數學）收成一列，
// 避免出現多列一模一樣的「數學 ／ Barney」。各班名以次要標籤呈現、不漏資訊。
function buildCourseRows(): CourseRow[] {
  const order = new Map(data.courses.map((c, i) => [c.slug, c.order ?? i]));
  const map = new Map<string, CourseRow>();
  for (const o of data.offerings) {
    const key = `${o.grade}__${o.subject}__${o.teacherSlug}`;
    let row = map.get(key);
    if (!row) {
      row = {
        rowKey: key,
        subject: o.subject,
        teacherName: o.teacherName,
        englishName: o.englishName ?? null,
        grade: o.grade,
        courseNames: [],
        byDay: new Map<number, string[]>(),
        locations: [],
        sortOrder: Number.MAX_SAFE_INTEGER,
      };
      map.set(key, row);
    }
    if (!row.courseNames.includes(o.courseName)) row.courseNames.push(o.courseName);
    row.sortOrder = Math.min(row.sortOrder, order.get(o.courseSlug) ?? Number.MAX_SAFE_INTEGER);
    const dayList = row.byDay.get(o.weekday) ?? [];
    if (!dayList.includes(o.locationShort)) dayList.push(o.locationShort);
    row.byDay.set(o.weekday, dayList);
    if (!row.locations.includes(o.locationShort)) row.locations.push(o.locationShort);
  }
  // 每列內的班名依課程目錄 order 排序（高一→高二→高三 自然順序）。
  const nameOrder = new Map(data.courses.map((c) => [c.name, c.order ?? Number.MAX_SAFE_INTEGER]));
  for (const row of map.values()) {
    row.courseNames.sort(
      (a, b) =>
        (nameOrder.get(a) ?? Number.MAX_SAFE_INTEGER) - (nameOrder.get(b) ?? Number.MAX_SAFE_INTEGER),
    );
  }
  return [...map.values()].sort((a, b) => a.sortOrder - b.sortOrder);
}

const courseRows = buildCourseRows();

// 學制分組：國中在前、高中在後（僅保留有列者）。
const GRADE_ORDER: ('國中' | '高中')[] = ['國中', '高中'];
const grouped = GRADE_ORDER.map((grade) => ({
  grade,
  rows: courseRows.filter((r) => r.grade === grade),
})).filter((g) => g.rows.length > 0);
const presentGrades = grouped.map((g) => g.grade);

// 篩選島的可序列化資料。
const filterRows: ScheduleFilterRow[] = courseRows.map((r) => ({
  courseSlug: r.rowKey,
  courseName: r.courseNames.join(' '),
  subject: r.subject,
  teacherName: r.teacherName,
  englishName: r.englishName,
  grade: r.grade,
  locations: r.locations,
}));
const subjectOptions = [...new Set(courseRows.map((r) => r.subject))];
const teacherOptions = [...new Set(courseRows.map((r) => r.teacherName))];
const locationOptions = [...new Set(courseRows.flatMap((r) => r.locations))];

// 教室對照（圖例與篩選短標籤）：取自 data.locations。
const locationLegend = [...data.locations]
  .sort((a, b) => a.order - b.order)
  .map((l) => ({
    short: l.shortLabel,
    label: l.name,
    address: l.address,
    href: l.website ?? null,
    isPrimary: l.isPrimary,
  }));
const shortToLabel = new Map(locationLegend.map((l) => [l.short, l.label]));

const pageUrl = SITE.url + '/schedule';
const jsonLd = [
  webPageJsonLd({
    name: '教室課表',
    description: '賈伯斯教室與忍文理教室的固定班課程授課日程課表，可依科目、老師、教室、學制篩選。',
    url: pageUrl,
  }),
  breadcrumbJsonLd([
    { label: '首頁', href: SITE.url + '/' },
    { label: '教室課表', href: pageUrl },
  ]),
];
---

<BaseLayout
  title="教室課表"
  description="賈伯斯教室與忍文理教室的固定班課程授課日程課表，可依科目、老師、教室、學制篩選。家教採個別排課，請假與補課規則請見課務說明。"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-6xl px-4 pt-8 lg:px-8">
    <Breadcrumbs items={[{ label: '教室課表' }]} />
  </div>

  <PageHero variant="paper" eyebrow="教室課表" glyph="週" tint="espresso">
    <Fragment slot="heading">課程授課日程</Fragment>
    <p class="max-w-3xl text-lg text-charcoal/80 leading-relaxed">
      下列以「課程（科目＋老師）」為單位，呈現賈伯斯教室與忍文理教室的固定班授課日程。
      家教採個別排課，不列入固定課表，請逕洽課務人員安排。
      各時段之確切上課時間與科目開班狀況，以教室公告為準。
    </p>

    <p class="mt-6 text-base text-charcoal/80 leading-relaxed">
      <a href="/policy" class="text-espresso underline hover:text-caramel"
        >請假補課規則請見課務說明 →</a
      >
    </p>
  </PageHero>

  {/* ── 課表 ─────────────────────────────────────────── */}
  <SectionFadeUp class="bg-cream/40 paper-grain border-y border-cream">
    <div
      class="mx-auto max-w-6xl px-4 py-12 lg:px-8 lg:py-16"
      data-schedule-scope
    >
      <h2
        id="timetable"
        class="scroll-mt-24 font-serif text-3xl lg:text-4xl font-bold text-charcoal flex items-center gap-3"
      >
        <span class="inline-block h-2 w-8 rounded-full bg-caramel" aria-hidden="true"></span>
        課表
      </h2>
      <p class="mt-4 max-w-3xl text-charcoal/80 leading-relaxed">
        每一列為一門課程（科目＋老師），星期欄內之標籤標示當日授課教室；同一門課可能橫跨多天、多間教室。
        各教室位置請見 <a href="/contact#locations" class="text-espresso underline hover:text-caramel">教室據點 →</a>
      </p>

      {/* 教室圖例：說明格內短標籤對應的教室與地址 */}
      <dl class="mt-6 flex flex-wrap gap-x-8 gap-y-3 text-sm">
        {
          locationLegend.map((r) => (
            <div class="flex items-center gap-2">
              <dt>
                <span class="inline-flex items-center justify-center rounded-md bg-caramel/20 px-2 py-0.5 text-xs font-bold text-espresso">
                  {r.short}
                </span>
              </dt>
              <dd class="text-charcoal/70">
                {
                  r.href ? (
                    <a
                      href={r.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-medium text-charcoal underline decoration-caramel/60 underline-offset-2 hover:text-espresso"
                    >
                      {r.label}
                    </a>
                  ) : (
                    <span class="font-medium text-charcoal">{r.label}</span>
                  )
                }
                <span class="ml-1 text-charcoal/60">
                  {r.address}
                  {!r.isPrimary && '（姊妹品牌）'}
                </span>
              </dd>
            </div>
          ))
        }
      </dl>

      {/* 篩選島（client:visible）：SSR 表格已完整輸出，島僅疊加篩選互動。 */}
      <div class="mt-8">
        <ScheduleFilter
          client:visible
          rows={filterRows}
          subjects={subjectOptions}
          teachers={teacherOptions}
          locations={locationOptions}
          grades={presentGrades}
        />
      </div>

      <div class="mt-6">
        {
          courseRows.length > 0 ? (
            <Fragment>
              <div data-table-wrap class="overflow-x-auto rounded-2xl border border-cream bg-chalk">
                <table class="w-full min-w-[720px] border-collapse text-left text-sm">
                  <caption class="sr-only">
                    固定班課程（科目與老師）每週一至週五授課日程與授課教室
                  </caption>
                  <thead>
                    <tr class="border-b border-cream bg-cream/40">
                      <th scope="col" class="px-4 py-3 font-serif font-bold text-charcoal">
                        課程（科目／老師）
                      </th>
                      {WEEKDAY_NUMS.map((n) => (
                        <th
                          scope="col"
                          class="px-3 py-3 text-center font-serif font-bold text-charcoal"
                        >
                          {WEEKDAY_LABELS[n]}
                        </th>
                      ))}
                    </tr>
                  </thead>
                  {grouped.map((group) => (
                    <tbody data-grade-group={group.grade}>
                      {/* 分組標題列：隨該組可見列一併由島切換顯示。 */}
                      <tr data-group-row data-grade={group.grade} class="bg-latte/60">
                        <th
                          scope="colgroup"
                          colspan={1 + WEEKDAY_NUMS.length}
                          class="px-4 py-2 text-left"
                        >
                          <span class="inline-flex items-center gap-2 font-serif text-sm font-bold text-espresso">
                            <span class="inline-block h-1.5 w-1.5 rounded-full bg-caramel" aria-hidden="true" />
                            {group.grade}
                          </span>
                        </th>
                      </tr>
                      {group.rows.map((row) => (
                        <tr
                          data-course-row
                          data-course-slug={row.rowKey}
                          data-grade={row.grade}
                          class="border-b border-cream/70 align-top"
                        >
                          <th
                            scope="row"
                            class="px-4 py-4 text-left font-normal whitespace-nowrap"
                          >
                            <span class="block max-w-[18rem] whitespace-normal font-serif text-base font-bold leading-snug text-charcoal">
                              {row.subject}
                            </span>
                            <span class="mt-1 block text-sm text-charcoal/70">
                              {row.teacherName}
                              {row.englishName && (
                                <span class="ml-1 text-charcoal/45">{row.englishName}</span>
                              )}
                            </span>
                            <span class="mt-1 block max-w-[18rem] whitespace-normal text-xs leading-snug text-charcoal/45">
                              {row.courseNames.join('・')}
                            </span>
                          </th>
                          {WEEKDAY_NUMS.map((n) => {
                            const dayRooms = row.byDay.get(n) ?? [];
                            return (
                              <td class="px-3 py-4 text-center">
                                {dayRooms.length > 0 ? (
                                  <span class="inline-flex flex-wrap items-center justify-center gap-1">
                                    {dayRooms.map((rm) => (
                                      <span
                                        class="inline-flex items-center justify-center rounded-full bg-caramel/20 px-2.5 py-1 text-xs font-bold text-espresso"
                                        aria-label={`${row.subject}（${row.teacherName}）${WEEKDAY_LABELS[n]}於${shortToLabel.get(rm) ?? rm}授課`}
                                      >
                                        {rm}
                                      </span>
                                    ))}
                                  </span>
                                ) : (
                                  <span class="text-charcoal/25" aria-hidden="true">
                                    —
                                  </span>
                                )}
                              </td>
                            );
                          })}
                        </tr>
                      ))}
                    </tbody>
                  ))}
                </table>
              </div>

              {/* 空狀態：島在「全部過濾掉」時顯示；SSR 預設隱藏。 */}
              <div
                data-empty-state
                hidden
                class="rounded-2xl border border-dashed border-cream bg-chalk px-5 py-10 text-center"
              >
                <p class="text-sm text-charcoal/70">
                  找不到符合條件的課程。請放寬篩選條件，或來電
                  <a href="tel:+88652230303" class="text-espresso hover:underline">(05) 223-0303</a>
                  由課務人員為您查詢。
                </p>
              </div>
            </Fragment>
          ) : (
            <p class="rounded-2xl border border-cream bg-chalk px-5 py-6 text-sm text-charcoal/70">
              固定班課表整理中，詳情請洽課務人員。
            </p>
          )
        }
      </div>

      <p class="mt-8 text-xs text-charcoal/55 leading-relaxed">
        說明：每一列為一門課程（科目與授課老師），星期欄內之標籤標示當日授課教室（{
          locationLegend.map((r) => `${r.short}＝${r.label}`).join('、')
        }）；同一門課可能橫跨多天、多間教室。實際各教室開班科目以現場公告與排課為準。如需確認特定班別時段，歡迎來電
        <a href="tel:+88652230303" class="text-espresso hover:underline">(05) 223-0303</a> 詢問。
      </p>

      <p class="mt-6 text-base text-charcoal/80 leading-relaxed">
        <a href="/policy" class="text-espresso underline hover:text-caramel"
          >請假補課規則請見課務說明 →</a
        >
      </p>
    </div>
  </SectionFadeUp>

  <SectionFadeUp>
    <div class="mx-auto max-w-3xl px-4 py-16 lg:px-8 lg:py-20 text-center">
      <h2 class="font-serif text-3xl lg:text-4xl font-bold text-charcoal">
        想確認時段或安排試聽？
      </h2>
      <p class="mt-4 text-charcoal/80">課務人員會在 1 個工作日內回覆，協助您安排合適的班別。</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">聯絡我們</Button>
        <Button href="/courses" variant="secondary" size="lg">看課程</Button>
      </div>
    </div>
  </SectionFadeUp>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import SectionFadeUp from '~/components/SectionFadeUp.astro';
import Button from '~/components/Button.astro';
import { breadcrumbJsonLd, webPageJsonLd } from '~/lib/jsonld';
import { SITE } from '~/lib/seo';

// ── 課表：JSON 資料驅動，科目取自 teachers collection ──────
// 設計目標：客戶用「科目」找老師，而非用老師名字找。
// 因此兩間教室合併為單一課表，每位老師一列；科目升為主要可見資訊，
// 每個星期格內以教室短標籤標示該日授課地點（同日兩教室則並列）。
const WEEKDAYS = ['週一', '週二', '週三', '週四', '週五'] as const;
type Weekday = (typeof WEEKDAYS)[number];
type Room = '賈伯斯' | '忍文理';

// 教室短標籤：格內空間有限，取最短可辨識字樣。
const ROOM_SHORT: Record<Room, string> = {
  賈伯斯: '賈伯斯',
  忍文理: '忍',
};

const teacherCollection = await getCollection('teachers');
const subjectsBySlug = new Map<string, string[]>(
  teacherCollection.map((t) => [t.id, t.data.subjects ?? []]),
);

const scheduleEntries = (await getCollection('schedule')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);

interface TeacherRow {
  teacher: string;
  subjects: string[];
  // 以星期為鍵，值為當天授課教室清單；無授課者不入鍵。
  byDay: Map<Weekday, Room[]>;
}

// 以「老師」聚合：每位老師合併其各教室排程為單列，
// 每個星期格內帶該日所屬教室（room）。
function buildTeacherRows(): TeacherRow[] {
  const rows: TeacherRow[] = [];
  for (const entry of scheduleEntries) {
    const fallback = entry.data.teacherSlug
      ? subjectsBySlug.get(entry.data.teacherSlug) ?? []
      : [];
    // 彙整各教室於該教室定義的科目；沿用 teachers collection 作為後備。
    const roomSubjects = entry.data.rooms.flatMap((r) => r.subjects ?? []);
    const subjects = roomSubjects.length > 0 ? [...new Set(roomSubjects)] : fallback;

    const byDay = new Map<Weekday, Room[]>();
    for (const roomData of entry.data.rooms) {
      for (const day of roomData.days as Weekday[]) {
        const list = byDay.get(day) ?? [];
        if (!list.includes(roomData.room)) list.push(roomData.room);
        byDay.set(day, list);
      }
    }
    if (byDay.size === 0) continue;
    rows.push({ teacher: entry.data.teacher, subjects, byDay });
  }
  return rows;
}

const teacherRows = buildTeacherRows();

// 教室對照（圖例與地址說明用）。
const roomLegend: { key: Room; short: string; label: string; note: string }[] = [
  {
    key: '賈伯斯',
    short: ROOM_SHORT['賈伯斯'],
    label: '賈伯斯教室',
    note: '嘉義市東區康樂街 10 號',
  },
  {
    key: '忍文理',
    short: ROOM_SHORT['忍文理'],
    label: '忍文理教室',
    note: '嘉義市西區杭州一街 38 號（姊妹品牌）',
  },
];

const pageUrl = SITE.url + '/schedule';
const jsonLd = [
  webPageJsonLd({
    name: '教室課表',
    description: '賈伯斯教室與忍文理教室的固定班教師授課日程課表。',
    url: pageUrl,
  }),
  breadcrumbJsonLd([
    { label: '首頁', href: SITE.url + '/' },
    { label: '教室課表', href: pageUrl },
  ]),
];
---

<BaseLayout
  title="教室課表"
  description="賈伯斯教室與忍文理教室的固定班教師授課日程課表。家教採個別排課，請假與補課規則請見課務說明。"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-6xl px-4 pt-8 lg:px-8">
    <Breadcrumbs items={[{ label: '教室課表' }]} />
  </div>

  <section class="bg-cream/40 paper-grain border-b border-cream">
    <div class="mx-auto max-w-6xl px-4 py-14 lg:px-8 lg:py-20">
      <p class="font-handwriting text-2xl text-espresso">教室課表</p>
      <h1 class="mt-2 font-serif text-4xl lg:text-6xl font-bold text-charcoal leading-tight">
        固定班教師課表
      </h1>
      <p class="mt-6 max-w-3xl text-lg text-charcoal/80 leading-relaxed">
        下列為賈伯斯教室與忍文理教室兩間教室的固定班教師授課日程。家教採個別排課，不列入固定課表，請逕洽課務人員安排。
        各時段之確切上課時間與科目開班狀況，以教室公告為準。
      </p>

      <p class="mt-6 text-base text-charcoal/80 leading-relaxed">
        <a href="/policy" class="text-espresso underline hover:text-caramel"
          >請假補課規則請見課務說明 →</a
        >
      </p>
    </div>
  </section>

  {/* ── 課表 ─────────────────────────────────────────── */}
  <SectionFadeUp class="bg-cream/40 paper-grain border-y border-cream">
    <div class="mx-auto max-w-6xl px-4 py-12 lg:px-8 lg:py-16">
      <h2
        id="timetable"
        class="scroll-mt-24 font-serif text-3xl lg:text-4xl font-bold text-charcoal flex items-center gap-3"
      >
        <span class="inline-block h-2 w-8 rounded-full bg-caramel" aria-hidden="true"></span>
        課表
      </h2>
      <p class="mt-4 max-w-3xl text-charcoal/80 leading-relaxed">
        下列為兩間教室的固定班教師授課日程。家教採個別排課，不列入固定課表，請逕洽課務人員安排。
        各時段之確切上課時間與科目開班狀況，以教室公告為準。
        各教室位置請見 <a href="/locations" class="text-espresso underline hover:text-caramel">教室據點 →</a>
      </p>

      {/* 教室圖例：說明格內短標籤對應的教室與地址 */}
      <dl class="mt-6 flex flex-wrap gap-x-8 gap-y-3 text-sm">
        {
          roomLegend.map((r) => (
            <div class="flex items-center gap-2">
              <dt>
                <span class="inline-flex items-center justify-center rounded-md bg-caramel/20 px-2 py-0.5 text-xs font-bold text-espresso">
                  {r.short}
                </span>
              </dt>
              <dd class="text-charcoal/70">
                <span class="font-medium text-charcoal">{r.label}</span>
                <span class="ml-1 text-charcoal/60">{r.note}</span>
              </dd>
            </div>
          ))
        }
      </dl>

      <div class="mt-8">
        {
          teacherRows.length > 0 ? (
            <div class="overflow-x-auto rounded-2xl border border-cream bg-chalk">
              <table class="w-full min-w-[680px] border-collapse text-left text-sm">
                <caption class="sr-only">固定班教師授課科目與每週授課日程</caption>
                <thead>
                  <tr class="border-b border-cream bg-cream/40">
                    <th scope="col" class="px-4 py-3 font-serif font-bold text-charcoal">
                      科目與教師
                    </th>
                    {WEEKDAYS.map((d) => (
                      <th
                        scope="col"
                        class="px-3 py-3 text-center font-serif font-bold text-charcoal"
                      >
                        {d}
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {teacherRows.map((row) => (
                    <tr class="border-b border-cream/70 last:border-b-0 align-top">
                      <th
                        scope="row"
                        class="px-4 py-4 text-left font-normal whitespace-nowrap"
                      >
                        {row.subjects.length > 0 && (
                          <span class="block max-w-[16rem] whitespace-normal font-serif text-base font-bold leading-snug text-charcoal">
                            {row.subjects.join('、')}
                          </span>
                        )}
                        <span class="mt-1 block text-sm font-medium text-charcoal/75">
                          {row.teacher}
                        </span>
                      </th>
                      {WEEKDAYS.map((d) => {
                        const dayRooms = row.byDay.get(d) ?? [];
                        return (
                          <td class="px-3 py-4 text-center">
                            {dayRooms.length > 0 ? (
                              <span class="inline-flex flex-wrap items-center justify-center gap-1">
                                {dayRooms.map((rm) => (
                                  <span
                                    class="inline-flex items-center justify-center rounded-full bg-caramel/20 px-2.5 py-1 text-xs font-bold text-espresso"
                                    aria-label={`${row.teacher} ${d}於${rm === '賈伯斯' ? '賈伯斯教室' : '忍文理教室'}授課`}
                                  >
                                    {ROOM_SHORT[rm]}
                                  </span>
                                ))}
                              </span>
                            ) : (
                              <span class="text-charcoal/25" aria-hidden="true">
                                —
                              </span>
                            )}
                          </td>
                        );
                      })}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <p class="rounded-2xl border border-cream bg-chalk px-5 py-6 text-sm text-charcoal/70">
              固定班課表整理中，詳情請洽課務人員。
            </p>
          )
        }
      </div>

      <p class="mt-8 text-xs text-charcoal/55 leading-relaxed">
        說明：左欄為各教師所授科目與姓名，星期欄內之標籤標示當日授課教室（{
          roomLegend.map((r) => `${r.short}＝${r.label}`).join('、')
        }）；同日於兩間教室授課者並列兩標籤。實際各教室開班科目以現場公告與排課為準。如需確認特定班別時段，歡迎來電
        <a href="tel:+88652230303" class="text-espresso hover:underline">(05) 223-0303</a> 詢問。
      </p>

      <p class="mt-6 text-base text-charcoal/80 leading-relaxed">
        <a href="/policy" class="text-espresso underline hover:text-caramel"
          >請假補課規則請見課務說明 →</a
        >
      </p>
    </div>
  </SectionFadeUp>

  <SectionFadeUp>
    <div class="mx-auto max-w-3xl px-4 py-16 lg:px-8 lg:py-20 text-center">
      <h2 class="font-serif text-3xl lg:text-4xl font-bold text-charcoal">
        想確認時段或安排試聽？
      </h2>
      <p class="mt-4 text-charcoal/80">課務人員會在 1 個工作日內回覆，協助您安排合適的班別。</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">聯絡我們</Button>
        <Button href="/courses" variant="secondary" size="lg">看課程</Button>
      </div>
    </div>
  </SectionFadeUp>
</BaseLayout>

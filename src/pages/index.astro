---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/Button.astro';
import SectionFadeUp from '~/components/SectionFadeUp.astro';
import CountUp from '~/components/CountUp';
import TeacherCard from '~/components/TeacherCard.astro';
import CourseCard from '~/components/CourseCard.astro';
import PostCard from '~/components/PostCard.astro';
import IconChalk from '~/components/IconChalk.astro';
import { localBusinessJsonLd, educationalOrgJsonLd } from '~/lib/jsonld';
import { ALL_LOCATIONS } from '~/lib/locations';

const lineUrl = import.meta.env.PUBLIC_LINE_URL || '#';

const advantages = [
  {
    icon: 'cup' as const,
    title: '臺大資工碩士領軍，多元背景師資',
    desc: '由臺大資工碩士 Barney 老師領軍，師資來自臺、清、交、嘉義大學、高師大等不同背景，個人最高 15 年教學資歷，把每一個觀念講到學生真的聽得懂。',
  },
  {
    icon: 'users' as const,
    title: '極小班 / 精緻班 / 小班 三種規模',
    desc: '依科目與年級彈性配置 2-14 人小班，每位學生卡住的地方，老師走到桌邊就看得到、改得到、跟得上。',
  },
  {
    icon: 'note' as const,
    title: '自編教材與盲點筆記',
    desc: '過去 12 年累積的題型分類與盲點筆記，比照學測與分科測驗趨勢更新，重觀念、不灌題海。',
  },
];

const featuredCoursesAll = await getCollection('courses');
const featuredCourses = featuredCoursesAll
  .filter((c) => c.data.featured)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 6);

const teachersAll = await getCollection('teachers');
const featuredTeachers = teachersAll
  .filter((t) => t.data.featured)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 3);

const testimonialsAll = await getCollection('testimonials');
const featuredTestimonials = testimonialsAll
  .filter((t) => t.data.featured)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 3);

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 3);

const jsonLd = [localBusinessJsonLd(), educationalOrgJsonLd()];
---

<BaseLayout
  title="賈伯斯數理教室"
  description="嘉義東區精英小班補習推薦 — 由臺大資工碩士領軍，師資來自臺、清、交、嘉義大學、高師大等背景，過去 12 年品牌資歷、極小班 / 精緻班 / 小班三種規模與自編教材，協助嘉中、嘉女、協同、輔仁學生踏實累積。歡迎安排免費試聽。"
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 paper-grain opacity-60"
    ></div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute right-[-10%] top-[10%] hidden lg:block"
    >
      <svg
        width="520"
        height="520"
        viewBox="0 0 520 520"
        fill="none"
        stroke="currentColor"
        stroke-width="1.2"
        class="text-espresso/15"
      >
        <circle cx="260" cy="260" r="200" />
        <circle cx="260" cy="260" r="140" />
        <path d="M120 260c40-80 240-80 280 0M120 260c40 80 240 80 280 0" />
        <path d="M260 80v360M80 260h360" stroke-dasharray="4 6" />
        <text x="320" y="120" font-family="Caveat" font-size="28" fill="currentColor" stroke="none">
          π · ∫ · ∑
        </text>
      </svg>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-20 lg:px-8 lg:py-32">
      <p class="font-handwriting text-2xl text-espresso mb-3">嘉義 · 東區 · 康樂街</p>
      <h1
        data-split-text
        class="font-serif text-5xl lg:text-7xl font-bold text-charcoal leading-[1.1] max-w-3xl"
      >
        在嘉義東區，<br />
        陪你把每個觀念<span class="chalk-underline">踏實累積</span>。
      </h1>
      <p class="mt-6 text-lg lg:text-2xl text-charcoal/85 max-w-2xl leading-relaxed">
        臺大資工碩士領軍 · 過去 12 年品牌資歷 · 極小班 / 精緻班 / 小班三種規模<br />
        我們相信「個別化關注」勝過大班灌輸，<br class="hidden md:block" />
        所以從 2014 年回到嘉義那天起，每位學生都被看見、被回應、被陪著走。
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button href="/contact" variant="primary" size="lg" magnetic>立即試聽</Button>
        <Button href="/courses" variant="secondary" size="lg">探索課程</Button>
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-charcoal/70">
        <span class="inline-flex items-center gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-caramel" aria-hidden="true"></span>
          臺大資工碩士領軍
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-caramel" aria-hidden="true"></span>
          嘉中、嘉女、協同、輔仁學生在這裡累積
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-caramel" aria-hidden="true"></span>
          試聽免費，沒有任何壓力
        </span>
      </div>
    </div>
  </section>

  {/* 三大優勢 */}
  <SectionFadeUp class="bg-cream/40 paper-grain border-y border-cream">
    <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
      <div class="max-w-2xl">
        <p class="font-handwriting text-2xl text-espresso">為什麼選擇我們</p>
        <h2 class="mt-2 font-serif text-3xl lg:text-4xl font-bold text-charcoal">
          過去 12 年，我們把這三件事做到極致
        </h2>
        <p class="mt-3 text-charcoal/75 leading-relaxed">
          不浮誇、不催促，把學生卡住的觀念講清楚——是我們從第一天就在做的事。
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {advantages.map((a) => (
          <article class="rounded-xl bg-chalk border border-cream p-6 lg:p-8 transition-[transform,box-shadow] duration-300 hover:-translate-y-1 hover:shadow-md">
            <div class="text-espresso mb-4">
              <IconChalk name={a.icon} size={40} />
            </div>
            <h3 class="font-serif text-xl font-bold text-charcoal">{a.title}</h3>
            <p class="mt-3 text-charcoal/80 leading-relaxed">{a.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </SectionFadeUp>

  {/* 數據區 */}
  <SectionFadeUp class="bg-latte">
    <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-20">
      <div class="grid gap-8 md:grid-cols-3 text-center">
        <div>
          <p class="font-serif text-5xl lg:text-6xl font-bold text-espresso">
            <CountUp client:visible to={12} suffix="+" />
          </p>
          <p class="mt-3 text-charcoal/80">年品牌資歷</p>
          <p class="mt-1 text-xs text-charcoal/55">EST. 2014 · 師資個人最高 15 年</p>
        </div>
        <div>
          <p class="font-serif text-5xl lg:text-6xl font-bold text-espresso">
            <CountUp client:visible to={1000} suffix="+" />
          </p>
          <p class="mt-3 text-charcoal/80">在地學生陪伴</p>
          <p class="mt-1 text-xs text-charcoal/55">嘉中 · 嘉女 · 協同 · 輔仁</p>
        </div>
        <div>
          <p class="font-serif text-5xl lg:text-6xl font-bold text-espresso">
            <CountUp client:visible to={2} from={1} />
            <span class="text-3xl text-charcoal/60">–</span>
            <CountUp client:visible to={14} from={4} />
          </p>
          <p class="mt-3 text-charcoal/80">人 多種小班規模</p>
          <p class="mt-1 text-xs text-charcoal/55">極小班 / 精緻班 / 小班 依科目而定</p>
        </div>
      </div>
    </div>
  </SectionFadeUp>

  {/* 課程精選 */}
  {featuredCourses.length > 0 && (
    <SectionFadeUp class="bg-cream/40 paper-grain border-y border-cream">
      <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="max-w-2xl">
            <p class="font-handwriting text-2xl text-espresso">課程精選</p>
            <h2 class="mt-2 font-serif text-3xl lg:text-4xl font-bold text-charcoal">
              依照年級節奏鋪陳的小班課
            </h2>
            <p class="mt-3 text-charcoal/75 leading-relaxed">
              從國中銜接到高三衝刺，每一階段都有對應的課程設計。
            </p>
          </div>
          <a
            href="/courses"
            class="inline-flex items-center gap-1 text-espresso hover:text-caramel font-medium"
          >
            查看所有課程
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {featuredCourses.map((c) => <CourseCard course={c} />)}
        </div>
      </div>
    </SectionFadeUp>
  )}

  {/* 師資精選 */}
  {featuredTeachers.length > 0 && (
    <SectionFadeUp>
      <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="max-w-2xl">
            <p class="font-handwriting text-2xl text-espresso">師資精選</p>
            <h2 class="mt-2 font-serif text-3xl lg:text-4xl font-bold text-charcoal">
              臺、清、交、嘉義大學、高師大資歷的老師，親自帶班
            </h2>
            <p class="mt-3 text-charcoal/75 leading-relaxed">
              每位老師都對自己帶的學生負起整個學期的責任，把每個觀念講到學生真的聽得懂。
            </p>
          </div>
          <a
            href="/teachers"
            class="inline-flex items-center gap-1 text-espresso hover:text-caramel font-medium"
          >
            認識所有師資
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {featuredTeachers.map((t) => <TeacherCard teacher={t} />)}
        </div>
      </div>
    </SectionFadeUp>
  )}

  {/* 學生見證 */}
  {featuredTestimonials.length > 0 && (
    <SectionFadeUp class="bg-cream/40 paper-grain border-y border-cream">
      <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
        <div class="max-w-2xl">
          <p class="font-handwriting text-2xl text-espresso">學生見證</p>
          <h2 class="mt-2 font-serif text-3xl lg:text-4xl font-bold text-charcoal">
            來自嘉中、嘉女、協同、輔仁的真實心得
          </h2>
        </div>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {featuredTestimonials.map((t) => (
            <figure class="rounded-xl bg-chalk border border-cream p-6 flex flex-col">
              <blockquote class="text-charcoal/85 leading-relaxed">
                「{t.data.quote}」
              </blockquote>
              <figcaption class="mt-5 pt-5 border-t border-cream/80 text-sm text-charcoal/70">
                <span class="font-medium text-charcoal">{t.data.studentName}</span>
                {t.data.school ? <> · {t.data.school}</> : null}
                {t.data.grade ? <> · {t.data.grade}</> : null}
              </figcaption>
            </figure>
          ))}
        </div>
        <div class="mt-8 text-center">
          <a
            href="/testimonials"
            class="inline-flex items-center gap-1 text-espresso hover:text-caramel font-medium"
          >
            查看所有見證
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </SectionFadeUp>
  )}

  {/* 最新文章 */}
  {latestPosts.length > 0 && (
    <SectionFadeUp>
      <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="max-w-2xl">
            <p class="font-handwriting text-2xl text-espresso">學習筆記</p>
            <h2 class="mt-2 font-serif text-3xl lg:text-4xl font-bold text-charcoal">
              來自教學現場的觀察與技巧
            </h2>
          </div>
          <a
            href="/posts"
            class="inline-flex items-center gap-1 text-espresso hover:text-caramel font-medium"
          >
            所有文章
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {latestPosts.map((p) => <PostCard post={p} />)}
        </div>
      </div>
    </SectionFadeUp>
  )}

  {/* 兩個校區簡訊 */}
  <SectionFadeUp>
    <div class="mx-auto max-w-6xl px-4 py-12 lg:px-8 lg:py-16">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="font-handwriting text-2xl text-espresso">兩個校區</p>
          <h2 class="mt-2 font-serif text-2xl lg:text-3xl font-bold text-charcoal">
            東區康樂街 · 西區杭州一街
          </h2>
        </div>
        <a
          href="/contact"
          class="inline-flex items-center gap-1 text-espresso hover:text-caramel font-medium"
        >
          看地圖
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {ALL_LOCATIONS.map((loc) => (
          <article class="rounded-xl border border-cream bg-chalk p-5 flex gap-4">
            <span class="font-handwriting text-3xl text-espresso/70 shrink-0">
              {loc.key === 'jobs' ? '東' : '西'}
            </span>
            <div>
              <p class="font-serif text-lg font-bold text-charcoal">{loc.name}</p>
              <p class="mt-1 text-sm text-charcoal/75 leading-relaxed">{loc.address}</p>
              {loc.foundedYear && (
                <p class="mt-1 text-xs text-charcoal/55">EST. {loc.foundedYear}</p>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </SectionFadeUp>

  {/* 試聽 CTA */}
  <SectionFadeUp class="bg-cream/50 paper-grain border-t border-cream">
    <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
        <div>
          <p class="font-handwriting text-2xl text-espresso">下一步</p>
          <h2 class="mt-2 font-serif text-3xl lg:text-4xl font-bold text-charcoal">
            試聽 1 堂課，<br />感受小班的差別。
          </h2>
          <p class="mt-4 text-charcoal/80 leading-relaxed">
            填寫右側表單，我們會在 1 個工作日內以電話或 LINE 聯絡您，安排試聽時段。
            若試聽後不適合，沒有任何壓力。
          </p>
          <ul class="mt-6 space-y-2 text-sm text-charcoal/80">
            <li class="flex gap-2"><span class="text-caramel">·</span> 試聽完全免費</li>
            <li class="flex gap-2"><span class="text-caramel">·</span> 試聽後與家長 10 分鐘簡短溝通</li>
            <li class="flex gap-2"><span class="text-caramel">·</span> 不會在試聽當天就要求做決定</li>
          </ul>
          <div class="mt-6 flex flex-wrap gap-3">
            <Button href="/contact" variant="primary" size="lg" magnetic>預約試聽</Button>
            <Button href={lineUrl} variant="secondary" size="lg" external={lineUrl !== '#'}>
              改用 LINE 詢問
            </Button>
          </div>
        </div>
        <div class="rounded-xl bg-chalk border border-cream p-6 lg:p-8">
          <h3 class="font-serif text-xl font-bold text-charcoal">試聽流程</h3>
          <ol class="mt-4 space-y-4 text-sm text-charcoal/80 leading-relaxed">
            <li class="flex gap-3">
              <span class="shrink-0 inline-flex h-7 w-7 items-center justify-center rounded-full bg-caramel/30 text-charcoal font-bold">1</span>
              <span><strong class="text-charcoal">填寫聯絡資訊</strong>：在<a href="/contact" class="chalk-underline">聯絡頁</a>留下姓名、電話、年級與想試聽的科目。</span>
            </li>
            <li class="flex gap-3">
              <span class="shrink-0 inline-flex h-7 w-7 items-center justify-center rounded-full bg-caramel/30 text-charcoal font-bold">2</span>
              <span><strong class="text-charcoal">1 個工作日內回覆</strong>：我們會電話或 LINE 聯繫，與您討論時段與班別配對。</span>
            </li>
            <li class="flex gap-3">
              <span class="shrink-0 inline-flex h-7 w-7 items-center justify-center rounded-full bg-caramel/30 text-charcoal font-bold">3</span>
              <span><strong class="text-charcoal">免費試聽 1 堂課</strong>：實際進班，感受小班節奏。</span>
            </li>
            <li class="flex gap-3">
              <span class="shrink-0 inline-flex h-7 w-7 items-center justify-center rounded-full bg-caramel/30 text-charcoal font-bold">4</span>
              <span><strong class="text-charcoal">家長簡短溝通</strong>：試聽後 10 分鐘與家長討論觀察。不在當天要求做決定。</span>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </SectionFadeUp>
</BaseLayout>

---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/Button.astro';
import { localBusinessJsonLd } from '~/lib/jsonld';

const lineUrl = import.meta.env.PUBLIC_LINE_URL || '#';

const advantages = [
  {
    icon: '☕',
    title: '台清交資歷師資',
    desc: '由台大資工碩士領軍，師資皆具台清交背景與 13 年以上教學經驗。',
  },
  {
    icon: '✎',
    title: '6-10 人精英小班',
    desc: '每位學生都能被個別關注，卡住的盲點老師走到桌邊就看見。',
  },
  {
    icon: '✦',
    title: '自編教材',
    desc: '13 年累積的題型與盲點筆記，去蕪存菁，比照學測與分科測驗趨勢更新。',
  },
];

const jsonLd = localBusinessJsonLd();
---

<BaseLayout
  title="賈伯斯數理教室"
  description="嘉義在地的精英小班補習機構，由台清交資歷師資領軍，13 年以上教學經驗，專攻國中至高中數理科目。歡迎安排免費試聽。"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  {/* Hero */}
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-4 py-20 lg:px-8 lg:py-32">
      <p class="font-handwriting text-2xl text-espresso mb-3">嘉義 · 東區 · 康樂街</p>
      <h1 class="font-serif text-5xl lg:text-7xl font-bold text-charcoal leading-tight">
        賈伯斯數理教室
      </h1>
      <p class="mt-6 text-xl lg:text-2xl text-charcoal/85 max-w-2xl leading-relaxed">
        台清交資歷師資 · 13 年教學經驗 · 6-10 人精英小班<br />
        把每位學生卡住的地方，看清楚、講明白。
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button href="/contact" variant="primary" size="lg">立即試聽</Button>
        <Button href="/courses" variant="secondary" size="lg">查看課程</Button>
      </div>
    </div>
  </section>

  {/* 三大優勢 */}
  <section class="bg-cream/40 paper-grain border-y border-cream">
    <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
      <h2 class="font-serif text-3xl lg:text-4xl font-bold text-charcoal text-center">
        為什麼選擇我們
      </h2>
      <p class="mt-3 text-center text-charcoal/70 max-w-xl mx-auto">
        過去 13 年來，我們把這三件事做到極致。
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          advantages.map((a) => (
            <article class="rounded-xl bg-chalk border border-cream p-6 lg:p-8 transition-all hover:-translate-y-1 hover:shadow-md">
              <div class="text-4xl text-espresso mb-4" aria-hidden="true">
                {a.icon}
              </div>
              <h3 class="font-serif text-xl font-bold text-charcoal">{a.title}</h3>
              <p class="mt-3 text-charcoal/80 leading-relaxed">{a.desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* 後續區塊（課程總覽 / 師資精選 / 學生見證 / 最新文章 / 試聽 CTA）將於 Phase 3 完整化 */}
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-3xl px-4 lg:px-8 text-center">
      <p class="font-handwriting text-3xl text-espresso">下一步</p>
      <h2 class="mt-3 font-serif text-3xl lg:text-4xl font-bold text-charcoal">
        歡迎安排免費試聽
      </h2>
      <p class="mt-4 text-charcoal/80 leading-relaxed">
        試聽 1 堂課，感受小班的差別。
        若不適合，沒有任何壓力。
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">預約試聽</Button>
        <Button href={lineUrl} variant="secondary" size="lg" external={lineUrl !== '#'}>
          加 LINE 詢問
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
